# ── Model (OpenAI-compatible endpoint) ───────────────────────────────────
# Default target is NVIDIA NIM. Replace with your own key — never commit a real one.
OPENAI_API_KEY=nvapi-your-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# Verified end-to-end on NIM: clean tool-calls, coherent answers, no repetition.
# Alternatives: deepseek-ai/deepseek-v4-pro, nvidia/nemotron-3-nano-30b-a3b (fast).
OPENAI_MODEL=openai/gpt-oss-120b

# Sampling — 0.6 / 0.95 is the sane default (1.0/1.0 produces gibberish on some models).
OPENAI_TEMPERATURE=0.6
OPENAI_TOP_P=0.95
OPENAI_MAX_TOKENS=16384

# Provider-specific reasoning budget (extra_body). Leave UNSET for NVIDIA NIM.
# THINKING_TOKEN_BUDGET=2000

# ── Command sandbox ──────────────────────────────────────────────────────
# auto | docker | subprocess | none   (auto = docker if a daemon is reachable)
CYBERHACKMYTHOS_SANDBOX_BACKEND=auto
CYBERHACKMYTHOS_SANDBOX_IMAGE=python:3.13-slim
# Allow sandboxed commands to reach the network. OFF is the key anti-exfil control.
CYBERHACKMYTHOS_SANDBOX_ALLOW_NETWORK=false
CYBERHACKMYTHOS_SANDBOX_CPU_SECONDS=120
CYBERHACKMYTHOS_SANDBOX_MEMORY_MB=1024
CYBERHACKMYTHOS_SANDBOX_PIDS_LIMIT=256
# Comma-separated env vars a sandboxed command may inherit. Secrets are absent by design.
# CYBERHACKMYTHOS_SHELL_ENV_ALLOWLIST=PATH,HOME,LANG,LC_ALL,TERM,TZ,TMPDIR

# ── fetch_webpage / SSRF ─────────────────────────────────────────────────
CYBERHACKMYTHOS_FETCH_ALLOW_PRIVATE=false   # true only if you must reach internal hosts
CYBERHACKMYTHOS_FETCH_USE_JINA=false        # true routes fetches via r.jina.ai (leaks URLs)
CYBERHACKMYTHOS_FETCH_MAX_BYTES=5000000

# ── App auth / limits ────────────────────────────────────────────────────
# Basic auth as "user:pass" pairs, comma-separated. REQUIRED for any shared deploy.
# CYBERHACKMYTHOS_APP_AUTH=analyst:changeme
CYBERHACKMYTHOS_MAX_ITERATIONS=60
CYBERHACKMYTHOS_TOOL_CACHE_MAX_ENTRIES=512

# ── Live testing / DAST ───────────────────────────────────────────────────
# OFF by default. DAST reaches LIVE hosts — enable ONLY to test your own assets
# or targets you have written authorization for. Scans of hosts not on the
# allowlist are refused. A leading "." allows subdomains (.example.com).
CYBERHACKMYTHOS_DAST_ENABLED=false
# CYBERHACKMYTHOS_AUTHORIZED_TARGETS=dev.evoketechnologies.com,.mycompany.com
CYBERHACKMYTHOS_DAST_TIMEOUT_SECONDS=600
