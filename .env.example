# ── Model (OpenAI-compatible endpoint) ───────────────────────────────────
# Default target is NVIDIA NIM. Replace with your own key — never commit a real one.
OPENAI_API_KEY=nvapi-your-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=z-ai/glm-5.1

# Sampling
OPENAI_TEMPERATURE=1
OPENAI_TOP_P=1
OPENAI_MAX_TOKENS=16384

# Provider-specific reasoning budget (extra_body). Leave UNSET for NVIDIA NIM.
# THINKING_TOKEN_BUDGET=2000

# ── Command sandbox ──────────────────────────────────────────────────────
# auto | docker | subprocess | none   (auto = docker if a daemon is reachable)
OPENMYTHOS_SANDBOX_BACKEND=auto
OPENMYTHOS_SANDBOX_IMAGE=python:3.13-slim
# Allow sandboxed commands to reach the network. OFF is the key anti-exfil control.
OPENMYTHOS_SANDBOX_ALLOW_NETWORK=false
OPENMYTHOS_SANDBOX_CPU_SECONDS=120
OPENMYTHOS_SANDBOX_MEMORY_MB=1024
OPENMYTHOS_SANDBOX_PIDS_LIMIT=256
# Comma-separated env vars a sandboxed command may inherit. Secrets are absent by design.
# OPENMYTHOS_SHELL_ENV_ALLOWLIST=PATH,HOME,LANG,LC_ALL,TERM,TZ,TMPDIR

# ── fetch_webpage / SSRF ─────────────────────────────────────────────────
OPENMYTHOS_FETCH_ALLOW_PRIVATE=false   # true only if you must reach internal hosts
OPENMYTHOS_FETCH_USE_JINA=false        # true routes fetches via r.jina.ai (leaks URLs)
OPENMYTHOS_FETCH_MAX_BYTES=5000000

# ── App auth / limits ────────────────────────────────────────────────────
# Basic auth as "user:pass" pairs, comma-separated. REQUIRED for any shared deploy.
# OPENMYTHOS_APP_AUTH=analyst:changeme
OPENMYTHOS_MAX_ITERATIONS=60
OPENMYTHOS_TOOL_CACHE_MAX_ENTRIES=512
